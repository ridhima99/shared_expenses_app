generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  groups        GroupMember[]
  expenses      Expense[]
  settlementsPayer Settlement[] @relation("SettlementPayer")
  settlementsReceiver Settlement[] @relation("SettlementReceiver")
  createdGroups Group[] @relation("GroupCreator")
  expenseParticipants ExpenseParticipant[] @relation("ExpenseParticipantUser")
  
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionId         String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  userId       String
  expires      DateTime
  accessToken  String?
  refreshToken String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([sessionId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  currency    String   @default("INR")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  creator     User        @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  importJobs  ImportJob[]
  
  @@index([createdBy])
  @@index([currency])
}

model GroupMember {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  joinDate    DateTime @default(now())
  leaveDate   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([groupId, userId, joinDate])
  @@index([groupId])
  @@index([userId])
  @@index([joinDate])
  @@index([leaveDate])
}

model Expense {
  id           String   @id @default(cuid())
  groupId      String
  title        String
  description  String?
  amount       Decimal  @db.Decimal(10, 2)
  currency     String   @default("INR")
  amountInBase Decimal  @db.Decimal(10, 2) @default(0)
  baseCurrency String   @default("INR")
  date         DateTime
  paidBy       String
  splitType    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  group        Group                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                     @relation(fields: [paidBy], references: [id], onDelete: Cascade)
  participants ExpenseParticipant[]
  
  @@index([groupId])
  @@index([paidBy])
  @@index([date])
  @@index([currency])
}

model ExpenseParticipant {
  id          String   @id @default(cuid())
  expenseId   String
  userId      String
  amount      Decimal  @db.Decimal(10, 2)
  percentage  Decimal? @db.Decimal(5, 2)
  shares      Decimal? @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation("ExpenseParticipantUser", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
}

model Settlement {
  id          String   @id @default(cuid())
  groupId     String
  payerId     String
  receiverId  String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer User  @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Cascade)
  receiver User @relation("SettlementReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  @@index([groupId])
  @@index([payerId])
  @@index([receiverId])
}

model ExchangeRate {
  id          String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(10, 6)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  
  @@unique([fromCurrency, toCurrency, date])
  @@index([fromCurrency])
  @@index([toCurrency])
  @@index([date])
}

model ImportJob {
  id            String      @id @default(cuid())
  groupId       String
  fileName      String
  totalRows     Int
  processedRows Int         @default(0)
  status        String      @default("PENDING")
  error         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rows    ImportRow[]
  
  @@index([groupId])
  @@index([status])
}

model ImportRow {
  id             String       @id @default(cuid())
  importJobId    String
  rowIndex       Int
  rawData        Json
  normalizedData Json?
  status         String       @default("PENDING")
  importError    String?
  anomalyReports AnomalyReport[]
  
  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  
  @@index([importJobId])
  @@index([status])
}

model AnomalyReport {
  id          String   @id @default(cuid())
  importRowId String
  type        String
  message     String
  severity    String   @default("WARNING")
  oldValue    String?
  newValue    String?
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  
  importRow ImportRow @relation(fields: [importRowId], references: [id], onDelete: Cascade)
  
  @@index([importRowId])
  @@index([type])
  @@index([severity])
  @@index([isResolved])
}